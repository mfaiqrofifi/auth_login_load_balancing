APP_ENV=development
APP_NAME=auth-service
APP_INSTANCE_NAME=local
PORT=8080

# Local Docker Compose database settings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth_service

# Prefer URLs in production. The host/port fields stay available for local/manual runs.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth_service?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_service
DB_SSLMODE=disable

REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=replace-this-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=168
JWT_ISSUER=auth-service
JWT_AUDIENCE=auth-clients

COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

REQUEST_TIMEOUT_SECONDS=15
SHUTDOWN_TIMEOUT_SECONDS=10
TRUST_PROXY_HEADERS=true
LOG_LEVEL=INFO

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type
CORS_ALLOW_CREDENTIALS=true

LOGIN_RATE_LIMIT_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
REGISTER_RATE_LIMIT_REQUESTS=3
REGISTER_RATE_LIMIT_WINDOW_SECONDS=60
REFRESH_RATE_LIMIT_REQUESTS=10
REFRESH_RATE_LIMIT_WINDOW_SECONDS=60
